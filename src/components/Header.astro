---
import SocialLinks from './SocialLinks.astro';
---

<a href="#main-content" class="skip-to-content">Skip to main content</a>
<header class="site-header">
	<div class="wrapper">
		<div class="header-inner">
			<a class="brand" href="/" title="Code with Dan | see it, learn it, code it">
				<img src="/images/codeWithDanLogo.png" alt="Code with Dan" width="250" height="59" />
			</a>
			<div class="header-right">
				<ul class="nav">
					<li><a href="https://www.pluralsight.com/authors/dan-wahlin" target="_blank">Video Courses</a></li>
				</ul>
				<div class="header-social">
					<SocialLinks />
				</div>
				<div class="header-search" id="header-search"></div>
				<button class="dark-mode-toggle" id="dark-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
					<svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M21.752 15.002A9.72 9.72 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/></svg>
					<svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zm4.5-6a6 6 0 100 12 6 6 0 000-12zm9.75 5.25a.75.75 0 010 1.5h-2.25a.75.75 0 010-1.5h2.25zM12 18.75a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0v-2.25a.75.75 0 01.75-.75zm-7.28-2.03a.75.75 0 011.06 0l1.59 1.59a.75.75 0 01-1.06 1.06l-1.59-1.59a.75.75 0 010-1.06zm14.56-9.44a.75.75 0 010 1.06l-1.59 1.59a.75.75 0 01-1.06-1.06l1.59-1.59a.75.75 0 011.06 0zM2.25 12a.75.75 0 01.75-.75h2.25a.75.75 0 010 1.5H3a.75.75 0 01-.75-.75zm16.03 4.72a.75.75 0 011.06 1.06l-1.59 1.59a.75.75 0 01-1.06-1.06l1.59-1.59zM7.28 5.69a.75.75 0 010 1.06L5.69 8.34a.75.75 0 01-1.06-1.06l1.59-1.59a.75.75 0 011.06 0z"/></svg>
				</button>
			</div>
			<button class="hamburger" id="hamburger" type="button" aria-label="Toggle menu" aria-expanded="false">
				<span></span>
				<span></span>
				<span></span>
			</button>
		</div>
	</div>
	<div class="mobile-menu" id="mobile-menu">
		<ul class="mobile-nav">
			<li><a href="https://www.pluralsight.com/authors/dan-wahlin" target="_blank">Video Courses</a></li>
		</ul>
		<div class="mobile-social">
			<SocialLinks />
		</div>
		<div class="mobile-search" id="mobile-search"></div>
	</div>
</header>

<script>
	import { PagefindUI } from '@pagefind/default-ui';

	function initSearch() {
		const headerEl = document.getElementById('header-search');
		if (headerEl && !headerEl.querySelector('.pagefind-ui')) {
			new PagefindUI({
				element: '#header-search',
				showSubResults: false,
				showImages: false,
				showEmptyFilters: false,
				excerptLength: 0,
			});
		}
	}

	function initMobileSearch() {
		const el = document.getElementById('mobile-search');
		if (el && !el.querySelector('.pagefind-ui')) {
			new PagefindUI({
				element: '#mobile-search',
				showSubResults: false,
				showImages: false,
				showEmptyFilters: false,
				excerptLength: 0,
			});
		}
	}

	function applyTheme() {
		const saved = localStorage.getItem('theme');
		const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
		const isDark = saved === 'dark' || (!saved && prefersDark);
		document.documentElement.classList.toggle('dark', isDark);
	}

	function bindToggle() {
		const toggle = document.getElementById('dark-toggle');
		const fresh = toggle?.cloneNode(true) as HTMLElement | null;
		if (toggle && fresh) {
			toggle.replaceWith(fresh);
			fresh.addEventListener('click', () => {
				const isDark = document.documentElement.classList.toggle('dark');
				localStorage.setItem('theme', isDark ? 'dark' : 'light');
			});
		}
	}

	function bindHamburger() {
		const btn = document.getElementById('hamburger');
		const menu = document.getElementById('mobile-menu');
		const fresh = btn?.cloneNode(true) as HTMLElement | null;
		if (btn && fresh && menu) {
			btn.replaceWith(fresh);
			fresh.addEventListener('click', () => {
				const isOpen = menu.classList.toggle('open');
				fresh.classList.toggle('active', isOpen);
				fresh.setAttribute('aria-expanded', String(isOpen));
				if (isOpen) initMobileSearch();
			});
		}
	}

	applyTheme();
	bindToggle();
	bindHamburger();
	initSearch();
	document.addEventListener('astro:after-swap', () => { applyTheme(); bindToggle(); bindHamburger(); initSearch(); });
</script>
