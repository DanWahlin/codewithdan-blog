---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, PAGE_SIZE } from '../../consts';

export async function getStaticPaths() {
	const allPosts = (await getCollection('blog'))
		.filter(p => !p.data.draft)
		.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
	const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
	return Array.from({ length: totalPages - 1 }, (_, i) => ({
		params: { page: String(i + 2) },
		props: {
			posts: allPosts.slice((i + 1) * PAGE_SIZE, (i + 2) * PAGE_SIZE),
			currentPage: i + 2,
			totalPages,
		},
	}));
}

const { posts, currentPage, totalPages } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} Blog - Page ${currentPage}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="wrapper">
			<div class="main-content" id="main-content">
				<div class="post-list">
					{posts.map((post) => (
						<PostCard post={post} />
					))}
				</div>

				<nav class="navigation">
					<ul class="pager">
						{currentPage < totalPages && (
							<li class="previous">
								<a href={`/page/${currentPage + 1}/`}>&larr; Older posts</a>
							</li>
						)}
						{currentPage > 1 && (
							<li class="next">
								<a href={currentPage - 1 === 1 ? '/' : `/page/${currentPage - 1}/`}>Newer posts &rarr;</a>
							</li>
						)}
					</ul>
				</nav>
			</div>
		</div>
		<Footer />
	</body>
</html>
