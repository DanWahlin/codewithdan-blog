---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, PAGE_SIZE } from '../consts';
import { getReadingTime } from '../utils/reading-time';
import { getExcerpt, getCoverImagePath } from '../utils/blog-helpers';

const allPosts = (await getCollection('blog'))
	.filter(p => !p.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const posts = allPosts.slice(0, PAGE_SIZE);
const heroPost = posts[0];
const remainingPosts = posts.slice(1);

const heroImage = getCoverImagePath(heroPost);
const heroExcerpt = getExcerpt(heroPost.body || '', 250);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} Blog`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="hero-banner">
			<div class="wrapper">
				<h1 class="hero-banner-title">
					<a href="/">AI, Agents &amp; Whatever Comes Next</a>
				</h1>
			</div>
		</div>

		<!-- Hero: Latest Post (full width) -->
		<div class="wrapper">
			<a href={`/${heroPost.id}/`} class="hero-card">
				{heroImage && (
					<div class="hero-card-image">
						<img src={heroImage} alt={`Cover image for: ${heroPost.data.title}`} loading="eager" />
					</div>
				)}
				<div class="hero-card-body">
					<span class="hero-label">Latest Post</span>
					<h2 class="hero-card-title">{heroPost.data.title}</h2>
					<p class="hero-card-excerpt">{heroExcerpt}</p>
					<div class="hero-card-meta">
						<FormattedDate date={heroPost.data.date} />
						<span class="hero-author">{getReadingTime(heroPost.body || '')}</span>
						<span class="hero-author">Dan Wahlin</span>
					</div>
				</div>
			</a>
		</div>

		<!-- Remaining posts -->
		<div class="wrapper">
			<div class="main-content" id="main-content">
				<div class="post-list">
					{remainingPosts.map((post) => (
						<PostCard post={post} />
					))}
				</div>

				{totalPages > 1 && (
					<nav class="navigation">
						<ul class="pager">
							<li class="previous">
								<a href="/page/2/">&larr; Older posts</a>
							</li>
						</ul>
					</nav>
				)}
			</div>
		</div>
		<Footer />
	</body>
</html>
